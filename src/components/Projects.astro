---
import { projects } from '../data/site';
---

<section data-screen-label="Projects">
  <h2>PROJECTS</h2>
  <div class="grid">
    {
      projects.map((p) => (
        <a class="card" href={p.href} target="_blank" rel="noopener noreferrer">
          <div class="thumb">
            <img src={p.image} alt={`${p.title} screenshot`} loading="lazy" />
          </div>
          <div class="body">
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <div class="tags">
              {p.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>

<style>
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 24px 20px;
  }

  h2 {
    font-weight: 700;
    font-size: clamp(14px, 1.6vw, 18px);
    color: var(--fg);
    margin: 0 0 24px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .card {
    border: 3px solid var(--fg);
    background: var(--card);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease;
  }

  .card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--fg);
  }

  .thumb {
    height: 150px;
    overflow: hidden;
    border-bottom: 3px solid var(--fg);
    background: var(--stripe-a);
  }

  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .body {
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  h3 {
    font-weight: 700;
    font-size: 12px;
    color: var(--fg);
    margin: 0;
  }

  p {
    font-size: 14px;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
    padding-top: 4px;
  }

  .tag {
    font-size: 11px;
    border: 2px solid var(--fg);
    padding: 2px 8px;
    color: var(--fg);
  }
</style>
