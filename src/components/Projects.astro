---
import { projects } from '../data/site';
---

<section data-screen-label="Projects">
  <h2>PROJECTS</h2>
  <div class="grid">
    {
      projects.map((p) => (
        <article class="card">
          <div class="thumb">
            <span>SCREENSHOT</span>
          </div>
          <div class="body">
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <div class="tags">
              {p.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 24px 20px;
  }

  h2 {
    font-weight: 700;
    font-size: clamp(14px, 1.6vw, 18px);
    color: var(--fg);
    margin: 0 0 24px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .card {
    border: 3px solid var(--fg);
    background: var(--card);
    display: flex;
    flex-direction: column;
  }

  .thumb {
    height: 150px;
    background: repeating-linear-gradient(
      45deg,
      var(--stripe-a) 0px,
      var(--stripe-a) 8px,
      var(--stripe-b) 8px,
      var(--stripe-b) 16px
    );
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 3px solid var(--fg);
  }

  .thumb span {
    font-size: 12px;
    color: var(--fg);
    background: var(--bg);
    padding: 4px 10px;
  }

  .body {
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  h3 {
    font-weight: 700;
    font-size: 12px;
    color: var(--fg);
    margin: 0;
  }

  p {
    font-size: 14px;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .tag {
    font-size: 11px;
    border: 2px solid var(--fg);
    padding: 2px 8px;
    color: var(--fg);
  }
</style>
