---
import { posts } from '../data/site';
---

<section data-screen-label="Writing">
  <h2>WRITING</h2>
  <div class="list">
    {
      posts.map((post) => (
        <article class="card">
          <div class="card-head">
            <h3>{post.title}</h3>
            <span class="date">{post.date}</span>
          </div>
          <p>{post.excerpt}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 24px 100px;
  }

  h2 {
    font-weight: 700;
    font-size: clamp(14px, 1.6vw, 18px);
    color: var(--fg);
    margin: 0 0 24px;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .card {
    border: 3px solid var(--fg);
    background: var(--card);
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  h3 {
    font-weight: 700;
    font-size: 12px;
    color: var(--fg);
    margin: 0;
  }

  .date {
    font-size: 13px;
    color: var(--muted);
  }

  p {
    font-size: 14px;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
