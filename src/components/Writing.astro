---
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);
---

<section id="writing" data-screen-label="Writing">
  <h2>WRITING</h2>
  <div class="list">
    {
      posts.map((post) => (
        <a class="card" href={`/writing/${post.id}`}>
          <div class="card-head">
            <h3>{post.data.title}</h3>
            <span class="date">{post.data.date}</span>
          </div>
          <p>{post.data.excerpt}</p>
          <span class="read-link">[ read post → ]</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 24px 100px;
  }

  h2 {
    font-weight: 700;
    font-size: clamp(14px, 1.6vw, 18px);
    color: var(--fg);
    margin: 0 0 24px;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .card {
    border: 3px solid var(--fg);
    background: var(--card);
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease;
  }

  .card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--fg);
  }

  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  h3 {
    font-weight: 700;
    font-size: 12px;
    color: var(--fg);
    margin: 0;
    text-align: left;
  }

  .date {
    font-size: 13px;
    color: var(--muted);
    flex-shrink: 0;
  }

  p {
    font-size: 14px;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
    text-align: left;
  }

  .read-link {
    font-size: 12px;
    color: var(--fg);
    margin-top: 4px;
  }
</style>
