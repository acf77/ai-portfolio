<section class="hero" data-screen-label="Hero">
  <h1 class="name-banner">
    <img
      class="banner banner-large"
      src="/images/name-banner-large.png"
      alt="Antonio Carlos Filho"
      width="1440"
      height="140"
      decoding="async"
    />
    <img
      class="banner banner-small"
      src="/images/name-banner-small.png"
      alt="Antonio Carlos Filho"
      width="1028"
      height="378"
      decoding="async"
    />
  </h1>
  <p class="tagline">&gt; Frontend, AI and Science_<span class="cursor">▌</span></p>

  <form id="ask-form">
    <div class="ask-box">
      <span class="prompt-char">&gt;</span>
      <input
        id="ask-input"
        type="text"
        placeholder="ask anything about me or my projects..."
        autocomplete="off"
        aria-label="Ask anything about me or my projects"
      />
      <button type="submit">SEND</button>
    </div>

    <p id="ask-thinking" class="thinking" hidden aria-live="polite">
      <span class="thinking-prompt">&gt;</span>
      <span class="square-spinner" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
      <span class="thinking-text">processing</span><span class="thinking-cursor">▌</span>
    </p>

    <div id="ask-response" class="response" role="status" hidden></div>
  </form>

  <div class="scroll-hint" aria-hidden="true">
    <span class="scroll-label">SCROLL</span>
    <span class="scroll-arrow">▼</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 24px;
    text-align: center;
    gap: 16px;
  }

  h1.name-banner {
    margin: 0;
    line-height: 0;
  }

  .banner {
    display: block;
    height: auto;
    max-width: 100%;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
  }

  :global(:root[data-theme='light']) .banner {
    filter: invert(1);
  }

  .banner-large {
    width: min(900px, 92vw);
  }

  .banner-small {
    display: none;
    width: min(180px, 52vw);
    margin-inline: auto;
  }

  @media (max-width: 767px) {
    .banner-large {
      display: none;
    }

    .banner-small {
      display: block;
    }
  }

  .tagline {
    font-size: clamp(14px, 1.8vw, 18px);
    color: var(--muted);
    margin: 0;
    letter-spacing: 1px;
  }

  .cursor {
    animation: blink 1s step-start infinite;
  }

  form {
    margin-top: 16px;
    width: min(560px, 90vw);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ask-box {
    display: flex;
    border: 3px solid var(--fg);
    background: var(--card);
  }

  .prompt-char {
    font-size: 16px;
    color: var(--muted);
    padding: 12px 0 12px 14px;
  }

  input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    color: var(--fg);
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    padding: 12px 10px;
  }

  input:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  button {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 10px;
    background: var(--fg);
    color: var(--bg);
    border: none;
    padding: 0 18px;
    cursor: pointer;
  }

  button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  button:hover:not(:disabled) {
    opacity: 0.85;
  }

  .thinking {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--muted);
    text-align: left;
    margin: 0;
  }

  .thinking-prompt {
    color: var(--fg);
    flex-shrink: 0;
  }

  .square-spinner {
    display: inline-flex;
    gap: 3px;
    flex-shrink: 0;
  }

  .square-spinner i {
    display: block;
    width: 8px;
    height: 8px;
    border: 2px solid var(--fg);
    box-sizing: border-box;
    animation: sq-blink 1s ease infinite;
  }

  .square-spinner i:nth-child(1) {
    animation-delay: 0s;
  }

  .square-spinner i:nth-child(2) {
    animation-delay: 0.15s;
  }

  .square-spinner i:nth-child(3) {
    animation-delay: 0.3s;
  }

  .square-spinner i:nth-child(4) {
    animation-delay: 0.45s;
  }

  @keyframes sq-blink {
    0%,
    40%,
    100% {
      background: transparent;
    }

    20% {
      background: var(--fg);
    }
  }

  .thinking-text {
    letter-spacing: 0.5px;
  }

  .thinking-cursor {
    animation: blink 1s step-start infinite;
  }

  .response {
    border: 3px solid var(--fg);
    background: var(--card);
    padding: 14px;
    text-align: left;
    font-size: 14px;
    color: var(--fg);
    line-height: 1.55;
  }

  .response :global(p) {
    margin: 0 0 0.75em;
  }

  .response :global(p:last-child) {
    margin-bottom: 0;
  }

  .response :global(ul),
  .response :global(ol) {
    margin: 0 0 0.75em;
    padding-left: 1.25em;
  }

  .response :global(li) {
    margin-bottom: 0.35em;
  }

  .response :global(a) {
    color: var(--fg);
    text-decoration: underline;
  }

  .response :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.92em;
    background: var(--stripe-b);
    padding: 0.1em 0.35em;
  }

  .response :global(pre) {
    margin: 0 0 0.75em;
    padding: 10px;
    overflow-x: auto;
    border: 2px solid var(--fg);
    background: var(--stripe-a);
  }

  .response :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .response :global(strong) {
    font-weight: 700;
  }

  .scroll-hint {
    position: absolute;
    bottom: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    animation: bounce 1.6s ease-in-out infinite;
  }

  .scroll-label {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 2px;
  }

  .scroll-arrow {
    color: var(--fg);
    font-size: 14px;
  }
</style>

<script>
  import DOMPurify from 'dompurify';
  import { marked } from 'marked';

  marked.setOptions({ breaks: true, gfm: true });

  const form = document.getElementById('ask-form') as HTMLFormElement;
  const input = document.getElementById('ask-input') as HTMLInputElement;
  const submitButton = form.querySelector('button') as HTMLButtonElement;
  const thinking = document.getElementById('ask-thinking')!;
  const response = document.getElementById('ask-response')!;

  function setPlainText(text: string) {
    response.textContent = text;
  }

  function setMarkdown(text: string) {
    const html = marked.parse(text) as string;
    response.innerHTML = DOMPurify.sanitize(html);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const message = input.value.trim();
    if (!message || input.disabled) return;

    thinking.hidden = false;
    response.hidden = true;
    input.disabled = true;
    submitButton.disabled = true;
    form.setAttribute('aria-busy', 'true');

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message }),
      });

      const data = (await res.json()) as { reply?: string; error?: string };

      if (!res.ok) {
        setPlainText(data.error ?? 'Something went wrong. Please try again.');
      } else {
        setMarkdown(data.reply ?? 'No response received.');
      }
      response.hidden = false;
    } catch {
      setPlainText('Could not reach the chat service. Check your connection and try again.');
      response.hidden = false;
    } finally {
      thinking.hidden = true;
      input.disabled = false;
      submitButton.disabled = false;
      form.removeAttribute('aria-busy');
      input.focus();
    }
  });
</script>
